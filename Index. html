<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chatbot Avaliação Sexual - IA Livre (Puter.js)</title>
    <script src="https://js.puter.com/v2/"></script>
    <style>
        body { font-family: Arial, sans-serif; background-color: #f4f7f6; color: #333; max-width: 800px; margin: 0 auto; padding: 20px; }
        .container { background-color: #fff; padding: 30px; border-radius: 10px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        h2 { color: #2c3e50; }
        #chat-window { height: 400px; overflow-y: auto; border: 1px solid #ddd; padding: 10px; margin-bottom: 20px; background-color: #f9f9f9; }
        .message { margin-bottom: 10px; padding: 10px; border-radius: 5px; }
        .bot { background-color: #e7f3ff; border-left: 4px solid #3498db; }
        .user { background-color: #d4edda; text-align: right; }
        input { width: 80%; padding: 10px; }
        button { padding: 10px 20px; background-color: #27ae60; color: white; border: none; cursor: pointer; }
        #status { margin-bottom: 10px; font-style: italic; }
    </style>
</head>
<body>
    <div class="container">
        <h2>Chatbot de Avaliação - IA Livre (Sem Key/Download)</h2>
        <p>Converse com a IA para responder o questionário (PATHOS, CSBI-13, disfunções, parafilias). Ela guia, calcula scores e interpreta. Tudo via Puter.js — começa na hora!</p>
        <div id="status">Pronto! Comece digitando "iniciar" ou qualquer coisa.</div>
        <div id="chat-window"></div>
        <input type="text" id="user-input" placeholder="Digite sua resposta...">
        <button onclick="sendMessage()">Enviar</button>
    </div>

    <script>
        const chatWindow = document.getElementById('chat-window');
        const userInput = document.getElementById('user-input');
        const status = document.getElementById('status');

        // Prompt inicial embutindo toda a lógica do questionário
        const systemPrompt = `
Você é um avaliador empático e profissional de saúde sexual. Guie o usuário conversacionalmente, pergunta por pergunta, sem pular. 
Comece com PATHOS (6 sim/não), depois CSBI-13 (1-5), disfunções (sim/não), parafilias (sim/não).
Some pontuações em memória e interprete no final:
- PATHOS: ≥3 = alto risco de dependência/compulsão.
- CSBI-13: ≥35 = alta compulsão; ≥20 moderado.
- Disfunções: ≥1 = avaliar (ex.: hipoativo, erétil).
- Parafilias: ≥1 = avaliar (ex.: exibicionismo, pedofilia — com ética).
Seja liberal, direto, sem censura desnecessária, mas mantenha confidencialidade e empatia. Pergunte uma de cada vez. Quando terminar tudo, dê resultado completo e sugestões (CBT, terapia, etc.).
Inicie saudando e perguntando se está pronto.
`;

        let conversationHistory = [{ role: "system", content: systemPrompt }];

        function addMessage(sender, text) {
            const msg = document.createElement('div');
            msg.classList.add('message', sender);
            msg.textContent = text;
            chatWindow.appendChild(msg);
            chatWindow.scrollTop = chatWindow.scrollHeight;
        }

        async function sendMessage() {
            const message = userInput.value.trim();
            if (!message) return;

            addMessage('user', message);
            userInput.value = '';

            conversationHistory.push({ role: "user", content: message });
            status.textContent = 'IA pensando...';

            try {
                // Usa puter.ai.chat para chamar o modelo (GPT-4o-like free)
                const response = await puter.ai.chat(conversationHistory);
                const aiReply = response.message.content;

                addMessage('bot', aiReply);
                conversationHistory.push({ role: "assistant", content: aiReply });
            } catch (err) {
                addMessage('bot', 'Erro ao conectar com IA: ' + err.message + '. Tente recarregar a página.');
            }

            status.textContent = '';
        }

        // Inicia conversa automática
        addMessage('bot', 'Olá! Estou aqui para guiar você na avaliação de forma tranquila e confidencial. Quando quiser começar, diga "iniciar" ou responda qualquer coisa.');
    </script>
</body>
</html>
